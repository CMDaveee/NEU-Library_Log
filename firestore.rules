rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Students ──────────────────────────────────────────────────────────────
    // Admins can only update isBlocked-related fields. Nobody can delete.
    match /students/{studentId} {
      allow read:   if request.auth != null;
      allow create: if true; // kiosk registration (unauthenticated)
      allow update: if request.auth != null &&
        request.auth.token.email in [
          'jcesperanza@neu.edu.ph',
          'daveandrew.claveria@neu.edu.ph'
        ] &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isBlocked', 'blockedBy', 'blockedAt', 'blockedReason']);
      allow delete: if false;
    }

    // ── Visits ────────────────────────────────────────────────────────────────
    // No deletion ever. Updates (checkout) only by authenticated users.
    match /visits/{visit} {
      allow read:   if request.auth != null;
      allow create: if true; // kiosk check-in (unauthenticated)
      allow update: if request.auth != null &&
        request.auth.token.email in [
          'jcesperanza@neu.edu.ph',
          'daveandrew.claveria@neu.edu.ph'
        ];
      allow delete: if false;
    }

  }
}
